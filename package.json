{
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=24",
        "pnpm": ">=11",
        "npm": "please-use-pnpm",
        "yarn": "please-use-pnpm"
    },
    "scripts": {
        "dev:vite": "vite --host",
        "dev:vite:scan": "vite --host --mode scan",
        "dev:tsc": "tsc --build --watch",
        "dev": "pnpm run --parallel \"/^dev:(vite|tsc)$/\"",
        "dev:scan": "pnpm run --parallel dev:vite:scan dev:tsc",
        "build": "vite build",
        "preview": "vite preview --host",
        "tsc": "tsc --build",
        "lint:eslint": "eslint --cache --max-warnings 0 --report-unused-disable-directives \"**/*.{js,ts,tsx,cjs,mjs}\"",
        "lint:stylelint": "stylelint --cache -q \"**/*.css\"",
        "lint:prettier": "prettier --check \"**/*.{js,ts,tsx,json,html,css,cjs,mjs}\"",
        "lint": "pnpm run \"/^lint:.*/\"",
        "fix:prettier": "prettier --write \"**/*.{js,ts,tsx,json,html,css,cjs,mjs}\"",
        "knip": "knip",
        "prepare": "husky"
    },
    "msw": {
        "workerDirectory": [
            "public"
        ]
    },
    "dependencies": {
        "@base-ui/react": "1.6.0",
        "@react-hookz/web": "25.2.0",
        "@tanstack/react-form": "1.33.0",
        "@tanstack/react-query": "5.101.2",
        "@tanstack/react-router": "1.170.17",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "ky": "2.0.2",
        "lucide-react": "1.23.0",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-error-boundary": "6.1.2",
        "sonner": "2.0.7",
        "tailwind-merge": "3.6.0",
        "zod": "4.4.3"
    },
    "devDependencies": {
        "@babel/core": "8.0.1",
        "@commitlint/cli": "21.2.0",
        "@commitlint/config-conventional": "21.2.0",
        "@eslint/js": "9.39.4",
        "@ianvs/prettier-plugin-sort-imports": "4.7.1",
        "@rolldown/plugin-babel": "0.2.3",
        "@tailwindcss/vite": "4.3.2",
        "@tanstack/eslint-plugin-query": "5.101.2",
        "@tanstack/eslint-plugin-router": "1.162.0",
        "@tanstack/react-query-devtools": "5.101.2",
        "@tanstack/react-router-devtools": "1.167.0",
        "@tanstack/router-plugin": "1.168.19",
        "@types/babel__core": "7.20.5",
        "@types/node": "24.13.2",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "6.0.3",
        "babel-plugin-react-compiler": "1.0.0",
        "eslint": "9.39.4",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-jsx-a11y": "6.10.2",
        "eslint-plugin-prettier": "5.5.6",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.1.1",
        "globals": "17.7.0",
        "husky": "9.1.7",
        "knip": "6.24.0",
        "msw": "2.14.6",
        "prettier": "3.9.4",
        "rollup-plugin-visualizer": "7.0.1",
        "shadcn": "4.13.0",
        "stylelint": "17.14.0",
        "stylelint-config-standard": "40.0.0",
        "tailwindcss": "4.3.2",
        "tw-animate-css": "1.4.0",
        "typescript": "6.0.3",
        "typescript-eslint": "8.62.1",
        "vite": "8.1.3",
        "vite-plugin-html": "3.2.2"
    }
}
